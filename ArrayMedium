import java.util.*;
class sol{
  public static void main(String[] args){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int[] arr=new int[n];
    for(int i=0;i<n;i++){
      arr[i]=sc.nextInt();
    }
    for(int i=n-1;i>=0;i--){
      for(int j=0;j<i;j++){
        if(arr[j]>arr[j+1]){
          int temp=arr[j];
          arr[j]=arr[j+1];
          arr[j+1]=temp;
        }
      }
    }
    for(int i=0;i<n;i++){
      System.out.print(arr[i]+" ");
    }
  }
}

import java.util.*;
class sol{
  public static void main(String[] args){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int[] arr=new int[n];
    for(int i=0;i<n;i++){
      arr[i]=sc.nextInt();
    }
    int count0=0;
    int count1=1;
    int count2=0;
    for(int a:arr){
      if(a==0) count0++;
      if(a==1) count1++;
      if(a==2) count2++;
    }
    int index=0;
    while(count0!=0){
      arr[index++]=0;
      count0--;
    }
    while(count1!=1){
      arr[index++]=1;
      count1--;
    }
    while(count2!=0){
      arr[index++]=2;
      count2--;
    }
    for(int i=0;i<n;i++){
      System.out.print(arr[i]+" ");
    }
  }
}

import java.util.*;
class sol{
  public static void main(String[] args){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int[] arr=new int[n];
    for(int i=0;i<n;i++){
      arr[i]=sc.nextInt();
    }
    int low=0;
    int mid=0;
    int high=n-1;
    while(mid<=high){
      if(arr[mid]==2){
        int temp=arr[mid];
        arr[mid]=arr[high];
        arr[high]=temp;
        high--;
      }
     else  if(arr[mid]==1){
        mid++;
      }
     else if(arr[mid]==0){
        int temp=arr[mid];
        arr[mid]=arr[low];
        arr[low]=temp;
        mid++;
        low++;
      }
    }
    for(int i=0;i<n;i++){
      System.out.print(arr[i]+" ");
    }
  }
}
