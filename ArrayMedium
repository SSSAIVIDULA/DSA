REARRANGE ELEMENTS BY SIGN 
import java.util.*;
class sol{
  public static void main(String[] args){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int[] arr=new int[n];
    for(int i=0;i<n;i++){
      arr[i]=sc.nextInt();
    }
    int[] res=new int[n];
    int pos=0;
    int neg=1;
    for(int i=0;i<n;i++){
      if(arr[i]>0){
        res[pos]=arr[i];
        pos=pos+2;
      }
      else{
        res[neg]=arr[i];
        neg=neg+2;
      }
    }
    for(int i=0;i<n;i++){
      System.out.print(res[i]+" ");
    }
  }
}
