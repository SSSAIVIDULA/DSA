import java.util.*;

class sol{
  public static void reverse(int[] arr,int start,int end){
    while(start<end){
      int temp=arr[start];
      arr[start]=arr[end];
      arr[end]=temp;
      start++;
      end--;
    }
  }
  public static void main(String[] args){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int[] arr=new int[n];
    for(int i=0;i<n;i++){
      arr[i]=sc.nextInt();
    }
    int index=-1;
    
    for(int i=n-2;i>=0;i--){
      if(arr[i]<arr[i+1]){
        index=i;
        break;
      }
    }
    for(int i=n-1;i>index;i--){
      if(arr[i]>arr[index]){
        int temp=arr[i];
        arr[i]=arr[index];
        arr[index]=temp;
        break;
      }
    }
    reverse(arr,index+1,arr.length-1);
    for(int i=0;i<n;i++){
      System.out.print(arr[i]);
    }
  }
}

