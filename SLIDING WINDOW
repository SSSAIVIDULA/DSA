MAXIMUM  SUBARRAY SUM IN GIVEN K SIZE 
import java.util.*;
class sol{
    public static void main(String[] args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int[] arr=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=sc.nextInt();
        }
        int sum=0;
        int k=sc.nextInt();
        for(int i=0;i<k;i++){
            sum+=arr[i];
        }
        int total=0;
        int max=sum;
        for(int i=k;i<n;i++){
            sum=sum+arr[i]-arr[i-k];
            total=Math.max(sum,total);
        }
        System.out.print(total);
    }
}
