MINIMUM SUBARRAY WITH SUM >= K
import java.util.*;
class sol{
  public static void main(String[] args){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int[] arr=new int[n];
    for(int i=0;i<n;i++){
      arr[i]=sc.nextInt();
    }
    int k=sc.nextInt();
    int start=0;
    int sum=0;
    int minimum=Integer.MAX_VALUE;
    for(int end=0;end<n;end++){
       
      sum=sum+arr[end];
      while(sum>k){
        sum=sum-arr[start];
        minimum=Math.min(minimum,end-start+1);
        start++;
      }
      
     end++;
    }
    System.out.print(minimum);
  }
}

