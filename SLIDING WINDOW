import java.util.*;
class sol{
  public static void main(String[] args){
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int[] arr=new int[n];
    for(int i=0;i<n;i++){
      arr[i]=sc.nextInt();
    }
    int k=sc.nextInt();
    int start=0;
    int maximum=0;
    int count=0;
    for(int end=0;end<n;end++){
      if(arr[end]==0){
        count++;
      }
      while(count>k){
        if(arr[start]==0){
          count--;
        }
        start++;
      }
      maximum=Math.max(maximum,end-start+1);
    }
    System.out.print(maximum);
  }
}
