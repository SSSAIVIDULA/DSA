MINIMUM SIZE SUBARRAY SUM 
class Solution {
    public int minSubArrayLen(int target, int[] nums) {
        int start=0;
        int end=0;
        int minimum=Integer.MAX_VALUE;
        int sum=0;
        while(end<nums.length){
             sum=sum+nums[end];
            while(sum>=target){
                 minimum=Math.min(minimum,end-start+1);
                sum=sum-nums[start];
                start++;
            } 
           end++;
        }
        return minimum==Integer.MAX_VALUE ? 0 : minimum; 
    }
}
